:root {
  --brand: #d7b15a;
  --brand-strong: #b8892d;
  --brand-deep: #6f4e12;
  --ink: #0f1b21;
  --ink-2: #24343d;
  --muted: #777d88;
  --line: #e8ebf0;
  --paper: #ffffff;
  --bg: #f8f6f1;
  --green: #20b79a;
  --red: #f25555;
  --gold-soft: #fbf3df;
  --blue: #2b86d9;
  --purple: #5d67e8;
}

page {
  min-height: 100%;
  color: var(--ink);
  background:
    radial-gradient(circle at 88% 0%, rgba(215, 177, 90, 0.14), transparent 320rpx),
    linear-gradient(180deg, #ffffff 0%, var(--bg) 420rpx);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 170rpx;
}

.dark-hero {
  overflow: hidden;
  position: relative;
  padding: 46rpx 36rpx;
  border-radius: 40rpx;
  color: #fff;
  background:
    radial-gradient(circle at 88% 12%, rgba(215, 177, 90, 0.32), transparent 210rpx),
    linear-gradient(145deg, #081217 0%, #13242c 58%, #0e1b21 100%);
  box-shadow: 0 30rpx 68rpx rgba(15, 27, 33, 0.18);
}

.dark-hero::after {
  content: "";
  position: absolute;
  right: -58rpx;
  bottom: -72rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(215, 177, 90, 0.14);
}

.eyebrow {
  color: var(--brand);
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 5rpx;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 60rpx;
  font-weight: 900;
  letter-spacing: -3rpx;
  line-height: 1.06;
}

.hero-subtitle {
  display: block;
  max-width: 520rpx;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 27rpx;
  line-height: 1.6;
}

.card {
  margin-top: 24rpx;
  padding: 30rpx;
  border: 1rpx solid var(--line);
  border-radius: 34rpx;
  background: var(--paper);
  box-shadow: 0 18rpx 46rpx rgba(16, 17, 20, 0.065);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 38rpx 0 18rpx;
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.section-kicker {
  display: block;
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 23rpx;
  font-weight: 500;
  line-height: 1.5;
}

.muted {
  color: var(--muted);
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 94rpx;
  border-radius: 999rpx;
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.26), transparent 46%),
    linear-gradient(135deg, var(--brand), var(--brand-strong));
  box-shadow:
    0 18rpx 40rpx rgba(184, 137, 45, 0.22),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.42);
}

.primary-btn[disabled] {
  opacity: 0.64;
}

.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 800;
  background: #fff;
}

.subtle-card {
  border-color: rgba(215, 177, 90, 0.18);
  background: linear-gradient(180deg, #fffdf7 0%, #ffffff 100%);
}

.row {
  display: flex;
  align-items: center;
}

.between {
  justify-content: space-between;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: var(--brand-deep);
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(215, 177, 90, 0.18);
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  padding: 22rpx 8rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: inset 0 0 0 1rpx rgba(16, 17, 20, 0.05);
}

.tool-item image {
  width: 56rpx;
  height: 56rpx;
}

.tool-item text {
  font-size: 23rpx;
  font-weight: 900;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.field {
  margin-top: 18rpx;
}

.label {
  display: block;
  margin-bottom: 10rpx;
  color: var(--ink-2);
  font-size: 25rpx;
  font-weight: 800;
}

.input,
.textarea,
.picker-box {
  width: 100%;
  min-height: 86rpx;
  padding: 0 24rpx;
  border: 1rpx solid var(--line);
  border-radius: 22rpx;
  color: var(--ink);
  font-size: 28rpx;
  background: #fbfcff;
}

.textarea {
  min-height: 136rpx;
  padding-top: 20rpx;
}

.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-box {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 24rpx 0;
  padding: 30rpx 32rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(215, 177, 90, 0.24), transparent 180rpx),
    #0f1b21;
  color: #fff;
  box-shadow: 0 22rpx 48rpx rgba(15, 27, 33, 0.18);
}

.price {
  color: var(--brand);
  font-size: 56rpx;
  font-weight: 900;
}

.status-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #0b7f55;
  font-size: 22rpx;
  font-weight: 800;
  background: rgba(24, 183, 123, 0.12);
}

.promise-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.promise {
  min-height: 172rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(215, 177, 90, 0.16);
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 94% 0%, rgba(215, 177, 90, 0.22), transparent 130rpx),
    linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
  box-shadow: 0 16rpx 42rpx rgba(16, 17, 20, 0.055);
}

.promise-code,
.promise-title,
.promise-desc {
  display: block;
}

.promise-code {
  color: var(--brand-deep);
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.promise-title {
  margin-top: 18rpx;
  font-size: 29rpx;
  font-weight: 900;
}

.promise-desc {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 23rpx;
  line-height: 1.5;
}
