.account-hero .hero-title {
  font-size: 48rpx;
}

.form-card {
  padding-top: 12rpx;
}

.field-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.field-head .label {
  margin-bottom: 0;
}

.field-icon {
  width: 38rpx;
  height: 38rpx;
}

.account-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 28rpx;
}

.text-btn {
  height: 72rpx;
  color: var(--muted);
  font-size: 25rpx;
  font-weight: 800;
}

.notice {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  color: var(--brand-deep);
  font-size: 23rpx;
  line-height: 1.7;
  background: rgba(215, 177, 90, 0.14);
}

.notice-icon {
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 42rpx;
}
