.brand-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.brand-name,
.brand-desc {
  display: block;
}

.brand-name {
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.brand-desc {
  margin-top: 4rpx;
  color: var(--muted);
  font-size: 22rpx;
}

.brand-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: var(--brand-deep);
  font-size: 22rpx;
  font-weight: 900;
  background: var(--gold-soft);
}

.hero-metrics {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 32rpx;
}

.hero-metric {
  padding: 18rpx 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
}

.metric-value,
.metric-label {
  display: block;
}

.metric-value {
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
}

.metric-label {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.62);
  font-size: 20rpx;
}

.hero-actions {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  margin-top: 28rpx;
}

.hero-action {
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex: 1 1 0;
  gap: 16rpx;
  width: auto;
  max-width: calc((100% - 16rpx) / 2);
  min-width: 0;
  height: 112rpx;
  margin: 0;
  padding: 0 22rpx 0 20rpx;
  border-radius: 28rpx;
  line-height: 1;
  white-space: nowrap;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.1),
    0 12rpx 26rpx rgba(0, 0, 0, 0.16);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.hero-action::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.14), transparent 50%);
}

.hero-action::after {
  content: "";
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  top: 14rpx;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
}

.hero-order {
  color: #fff;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.08), transparent 54%),
    linear-gradient(135deg, rgba(40, 42, 47, 0.9), rgba(23, 24, 29, 0.82));
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.hero-service {
  color: #fff;
  background:
    linear-gradient(180deg, rgba(247, 227, 179, 0.14), transparent 56%),
    linear-gradient(135deg, rgba(118, 89, 29, 0.86), rgba(78, 58, 18, 0.8));
  border: 1rpx solid rgba(231, 202, 139, 0.24);
}

.hero-action-icon-wrap {
  position: relative;
  z-index: 1;
  display: grid;
  place-items: center;
  flex: 0 0 60rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(245, 247, 252, 0.88));
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.86),
    0 8rpx 18rpx rgba(0, 0, 0, 0.12);
}

.hero-action-icon {
  position: relative;
  z-index: 1;
  width: 36rpx;
  height: 36rpx;
}

.hero-action-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex: 1 1 auto;
  min-width: 0;
  flex-direction: column;
  align-items: flex-start;
  gap: 4rpx;
  overflow: hidden;
}

.hero-action-title,
.hero-action-desc {
  position: relative;
  z-index: 1;
  display: block;
  width: 100%;
  min-width: 0;
  text-align: left;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-action-title {
  font-size: 26rpx;
  font-weight: 900;
  letter-spacing: 0.2rpx;
}

.hero-action-desc {
  color: rgba(255, 255, 255, 0.56);
  font-size: 18rpx;
}

.hero-action-arrow {
  position: relative;
  z-index: 1;
  flex: 0 0 auto;
  margin-left: auto;
  color: rgba(255, 255, 255, 0.7);
  font-size: 34rpx;
  font-weight: 500;
  line-height: 1;
}

.hero-btn {
  width: 100%;
}

.quick {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.quick-icon-wrap {
  display: grid;
  place-items: center;
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6f7fb 100%);
  box-shadow: inset 0 0 0 1rpx var(--line);
}

.quick-icon {
  width: 58rpx;
  height: 58rpx;
}

.quick-name {
  font-size: 24rpx;
  font-weight: 900;
}

.quick-desc {
  color: var(--muted);
  font-size: 20rpx;
}

.small {
  font-size: 24rpx;
  font-weight: 500;
}

.address-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  height: 92rpx;
  border-bottom: 1rpx solid var(--line);
}

.address-line:last-of-type {
  border-bottom: 0;
}

.address-line input {
  flex: 1;
  height: 88rpx;
  font-size: 29rpx;
}

.line-icon {
  width: 46rpx;
  height: 46rpx;
  flex: 0 0 46rpx;
}

.estimate-result {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 26rpx 0;
}

.estimate-price {
  display: block;
  margin-top: 4rpx;
  font-size: 64rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.estimate-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  color: var(--muted);
  font-size: 24rpx;
}

.flow-card {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 22rpx;
}

.flow-step {
  min-height: 118rpx;
  padding: 18rpx 12rpx;
  border-radius: 24rpx;
  background: #f7f8fb;
}

.flow-icon {
  width: 42rpx;
  height: 42rpx;
}

.flow-num,
.flow-name {
  display: block;
}

.flow-num {
  color: var(--brand-strong);
  font-size: 22rpx;
  font-weight: 900;
}

.flow-name {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.25;
}

.promise-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.promise {
  position: relative;
  overflow: hidden;
  min-height: 154rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 34rpx rgba(16, 17, 20, 0.05);
}

.promise::after {
  content: "";
  position: absolute;
  right: -34rpx;
  top: -34rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(215, 177, 90, 0.14);
}

.promise-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.promise-icon {
  width: 48rpx;
  height: 48rpx;
}

.promise-code {
  display: block;
  color: var(--brand-strong);
  font-size: 22rpx;
  font-weight: 900;
}

.promise-title {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
}

.promise-desc {
  display: block;
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 23rpx;
  line-height: 1.5;
}
