<view class="page">
  <view class="card query-card">
    <view class="query-title">
      <image src="/assets/ui/route.png" mode="aspectFit" />
      <view>
        <text class="query-heading">查快递</text>
        <text class="muted">输入运单号，查看快件轨迹</text>
      </view>
    </view>
    <view class="query-box">
      <input value="{{queryNo}}" placeholder="请输入运单号，如 SFH20260510001" bindinput="onQueryInput" />
      <button bindtap="searchWaybill">查询</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card empty">
    <text class="empty-title">正在查询</text>
    <text class="muted">请稍候，系统正在同步运单状态。</text>
  </view>

  <view wx:elif="{{errorText}}" class="empty card">
    <text class="empty-title">查询提示</text>
    <text class="muted">{{errorText}}</text>
    <button class="primary-btn" bindtap="loadOrder">查看最近订单</button>
  </view>

  <view wx:elif="{{order}}" class="track-card dark-hero">
    <text class="eyebrow">WAYBILL TRACKING</text>
    <text class="hero-title">{{statusText}}</text>
    <text class="hero-subtitle">运单 {{order.waybillNo}} · {{order.serviceType}} · {{order.eta}}</text>
    <view class="courier-card">
      <view>
        <text class="courier-name">{{order.courierName}}</text>
        <text class="courier-phone">{{order.courierPhone}}</text>
      </view>
      <button class="call-btn" bindtap="callCourier">
        <image src="/assets/ui/phone.png" mode="aspectFit" />
        <text>联系收派员</text>
      </button>
    </view>
  </view>

  <view wx:if="{{order}}" class="card route-card">
    <view class="route-card-head">
      <text class="route-card-title">配送路线</text>
      <text class="route-card-desc">寄件与收件信息</text>
    </view>
    <view class="route-path">
      <view class="route-stop">
        <view class="route-stop-icon route-stop-icon-from">
          <image class="route-icon" src="/assets/ui/pickup.png" mode="aspectFit" />
        </view>
        <view class="route-stop-copy">
          <text class="route-label">寄件地址</text>
          <text class="route-text">{{order.fromAddress}}</text>
        </view>
      </view>
      <view class="route-divider">
        <view class="route-divider-line"></view>
      </view>
      <view class="route-stop">
        <view class="route-stop-icon route-stop-icon-to">
          <image class="route-icon" src="/assets/ui/dropoff.png" mode="aspectFit" />
        </view>
        <view class="route-stop-copy">
          <text class="route-label">收件地址</text>
          <text class="route-text">{{order.toAddress}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{order}}" class="card timeline">
    <view class="step {{item.done ? 'done' : ''}}" wx:for="{{steps}}" wx:key="key">
      <view class="step-dot">
        <image src="/assets/ui/route.png" mode="aspectFit" />
      </view>
      <view class="step-body">
        <text class="step-title">{{item.title}}</text>
        <text wx:if="{{item.time}}" class="step-time">{{item.time}}</text>
        <text class="step-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="empty card">
    <text class="empty-title">暂无可查询订单</text>
    <text class="muted">你可以输入运单号，或先创建一个寄件订单。</text>
    <button class="primary-btn" bindtap="goOrder">去寄件</button>
  </view>
</view>
