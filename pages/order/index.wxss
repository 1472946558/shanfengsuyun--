.order-head {
  margin-bottom: 26rpx;
}

.order-head .hero-title {
  font-size: 50rpx;
}

.order-mini-flow {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 30rpx;
}

.order-mini-flow view {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  border-radius: 999rpx;
  color: rgba(255, 255, 255, 0.78);
  text-align: center;
  font-size: 23rpx;
  font-weight: 900;
  background: rgba(255, 255, 255, 0.1);
}

.order-mini-flow image {
  width: 34rpx;
  height: 34rpx;
}

.field-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.field-head .label {
  margin-bottom: 0;
}

.field-icon {
  width: 38rpx;
  height: 38rpx;
}

.price-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.price-box {
  margin-top: 26rpx;
  padding: 38rpx 34rpx;
  border: 1rpx solid rgba(215, 177, 90, 0.28);
}

.price-icon {
  display: block;
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 10rpx;
}

.price-box .muted {
  color: rgba(255, 255, 255, 0.58);
}

.price-label {
  display: block;
  color: rgba(255, 255, 255, 0.52);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.distance-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: var(--ink);
  font-size: 24rpx;
  font-weight: 900;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent 55%),
    var(--brand);
  box-shadow: 0 10rpx 24rpx rgba(215, 177, 90, 0.2);
}

.notice {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  color: var(--brand-deep);
  font-size: 23rpx;
  line-height: 1.6;
  background: linear-gradient(180deg, #fffaf0 0%, #ffffff 100%);
  box-shadow: inset 0 0 0 1rpx rgba(215, 177, 90, 0.18);
}

.notice-icon {
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 42rpx;
}
